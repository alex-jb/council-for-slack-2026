# Council for Slack — env var template
# Copy to .env.local and fill in real values. .env.local is gitignored.

# ── Slack ────────────────────────────────────────────────
# From https://api.slack.com/apps/<your-app-id>/general
SLACK_APP_ID=A0XXXXXXXX
SLACK_CLIENT_ID=11111111111.22222222222222
SLACK_CLIENT_SECRET=00000000000000000000000000000000
SLACK_SIGNING_SECRET=00000000000000000000000000000000

# From "Install to Workspace" or OAuth flow
SLACK_BOT_TOKEN=xoxb-...

# ── Anthropic ────────────────────────────────────────────
# council-diff drives 5 personas + Oracle via Sonnet 4.6
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (decision log + Brier persistence) ──────────
# Create a free-tier project at https://supabase.com/dashboard
# Apply migrations/*.sql in the Dashboard SQL Editor.
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Optional: only needed if you run direct SQL ops outside the RPC layer.
# Bot does not need this in normal operation.
SUPABASE_SERVICE_ROLE_KEY=

# ── Vercel (auto-set in deployment; leave blank locally) ─
VERCEL_URL=
