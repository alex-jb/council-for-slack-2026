flowchart TD
    U["<b>Slack user</b><br/>types /council-audit or drops<br/>Council deliberate step into a workflow"]:::user

    subgraph SLACK["Slack workspace"]
        direction TB
        SC["<b>Slash command</b><br/>/council-audit"]:::slack
        WB["<b>Workflow Builder</b><br/>custom function<br/>council_deliberate"]:::rubric
        MS["<b>Message shortcut</b><br/>Send to council"]:::slack
    end

    U --> SC
    U --> WB
    U --> MS

    SC --> API
    WB --> API
    MS --> API

    API["<b>events.ts</b> Bolt handler<br/>on Vercel serverless<br/>processBeforeResponse: true"]:::server

    API --> CTX["<b>Context assembly</b><br/>channel history + thread + attachments"]:::server

    CTX --> DISP["<b>council-diff engine dispatch</b><br/>5 parallel Anthropic Sonnet 4.6 calls"]:::server

    DISP --> V1["Voice 1<br/>YC Partner"]:::voice
    DISP --> V2["Voice 2<br/>Tier-1 VC Skeptic"]:::voice
    DISP --> V3["Voice 3<br/>Lawyer"]:::voice
    DISP --> V4["Voice 4<br/>Indie CFO"]:::voice
    DISP --> V5["Voice 5<br/>Pragmatic Spouse"]:::voice

    V1 --> AGG["<b>Aggregator</b><br/>agreement score + verdict + consensus"]:::server
    V2 --> AGG
    V3 --> AGG
    V4 --> AGG
    V5 --> AGG

    AGG --> DB[("<b>Supabase</b><br/>council_decisions<br/>SECURITY DEFINER RPC")]:::store
    AGG --> POST["<b>Slack reply</b><br/>Block Kit verdict in thread<br/>+ ✅/❌ resolve buttons"]:::server
    AGG --> CANVAS["<b>Channel Canvas</b><br/>appendCanvasLog<br/>auto-pinned decision log"]:::rubric

    POST --> THREAD["<b>Thread reply</b><br/>verdict + agreement + 5-voice scorecard<br/>+ Ed25519 attestation payload"]:::slack
    CANVAS --> THREAD

    MCP["<b>MCP server</b><br/>mcp/src/server.mjs<br/>tool card at /.well-known/mcp-cards/council.json"]:::rubric
    MCP -.same engine.-> DISP
    CLAUDE["Claude Desktop<br/>Cursor · Claude Code"]:::external
    CLAUDE --> MCP

    RESOLVE["<b>User resolves</b><br/>✅ Happened / ❌ Did not"]:::user
    THREAD --> RESOLVE
    RESOLVE --> BRIER["<b>Brier score</b><br/>per voice · per workspace<br/>calibration meta-metric"]:::server
    BRIER --> DB
    BRIER --> CANVAS

