%% ─── RENDER TO SVG ───────────────────────────────────────────────────────────
%%
%% Prereqs: Node 18+ available (system Node or via nvm). The renderer downloads
%% a headless Chromium the first time it runs, ~120 MB, one-time.
%%
%% From this directory:
%%
%%   npx -y @mermaid-js/mermaid-cli \
%%     -i architecture-diagram.mmd \
%%     -o architecture-diagram.svg \
%%     -b transparent \
%%     -w 1600
%%
%% For a PNG (for Devpost cover image slot):
%%
%%   npx -y @mermaid-js/mermaid-cli \
%%     -i architecture-diagram.mmd \
%%     -o architecture-diagram.png \
%%     -b "#0B1D2A" \
%%     -w 1920 -H 1080
%%
%% Verify the SVG opens cleanly in a browser before Devpost upload. Devpost's
%% Markdown renderer supports SVG in images gallery via direct upload. Commit
%% the generated .svg alongside this .mmd so judges can inspect either source.
%%
%% If the renderer complains about puppeteer download, prepend:
%%   PUPPETEER_SKIP_DOWNLOAD=false PUPPETEER_DOWNLOAD_HOST=https://npmmirror.com/mirrors
%% to work around US network flakiness.
