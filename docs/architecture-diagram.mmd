    classDef voice fill:#183043,stroke:#7FBFD4,color:#E6F7FF,stroke-width:1px
    classDef store fill:#1F3A2A,stroke:#5FD46F,color:#E6F7FF,stroke-width:1px
    classDef external fill:#2A1F3A,stroke:#B47FD4,color:#E6F7FF,stroke-width:1px

    linkStyle default stroke:#4A9DB8,stroke-width:1.5px

